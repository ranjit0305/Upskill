# Copy this file to .env and update with your actual values

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=upskill_db

# JWT Configuration - CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Judge0 API Configuration
# Get your API key from: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-rapidapi-key-here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Llama Model Configuration
LLAMA_MODEL_PATH=models/llama-2-7b-chat.gguf
LLAMA_CONTEXT_SIZE=2048
LLAMA_MAX_TOKENS=512

# Application Configuration
APP_NAME=Upskill
APP_VERSION=1.0.0
DEBUG=True
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
